{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "agents", "findings", "disagreements", "next_steps"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "needs-attention"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "verdict", "summary", "finding_count"],
        "properties": {
          "role": { "type": "string" },
          "verdict": { "type": "string" },
          "summary": { "type": "string" },
          "finding_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "title",
          "body",
          "file",
          "line_start",
          "line_end",
          "confidence",
          "recommendation",
          "source_agent"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "file": { "type": ["string", "null"] },
          "line_start": { "type": ["integer", "null"], "minimum": 1 },
          "line_end": { "type": ["integer", "null"], "minimum": 1 },
          "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "recommendation": { "type": ["string", "null"] },
          "source_agent": { "type": ["string", "null"] }
        }
      }
    },
    "disagreements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["topic", "positions", "resolution"],
        "properties": {
          "topic": { "type": "string" },
          "positions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "resolution": { "type": "string" }
        }
      }
    },
    "next_steps": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
